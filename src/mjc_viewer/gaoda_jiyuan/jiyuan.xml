  <actuator>
    <!-- 扭矩限制策略：
         - Hip pitch: 2.5 Nm (控制大腿前后摆动，功率较小)
         - Hip yaw/roll: 8 Nm
         - Knee: 8 Nm
         - Ankle (pitch/roll/yaw): 2.5 Nm (脚踝关节，精细控制)
         - Toe: 8 Nm
    -->

    <!-- 右腿 -->
    <motor name="right_hip_pitch_joint_ctrl" joint="right_hip_cube_joint" class="motor"
      ctrlrange="-2.5 2.5" forcerange="-2.5 2.5" />
    <motor name="right_hip_yaw_joint_ctrl" joint="right_thigh_joint" class="motor"
      ctrlrange="-8 8" forcerange="-8 8" />
    <motor name="right_hip_roll_joint_ctrl" joint="right_hip_roll_joint" class="motor"
      ctrlrange="-8 8" forcerange="-8 8" />
    <motor name="right_knee_joint_ctrl" joint="right_knee_joint" class="motor"
      ctrlrange="-8 8" forcerange="-8 8" />
    <motor name="right_ankle_pitch_ctrl" joint="right_ankle_cube_joint" class="motor"
      ctrlrange="-2.5 2.5" forcerange="-2.5 2.5" />
    <motor name="right_ankle_roll_ctrl" joint="right_ankle_axle_joint" class="motor"
      ctrlrange="-2.5 2.5" forcerange="-2.5 2.5" />
    <motor name="right_ankle_yaw_ctrl" joint="right_foot_joint" class="motor"
      ctrlrange="-2.5 2.5" forcerange="-2.5 2.5" />
    <motor name="right_toe_joint_ctrl" joint="right_toe_joint" class="motor"
      ctrlrange="-8 8" forcerange="-8 8" />

    <!-- 左腿 -->
    <motor name="left_hip_pitch_joint_ctrl" joint="left_hip_cube_joint" class="motor"
      ctrlrange="-2.5 2.5" forcerange="-2.5 2.5" />
    <motor name="left_hip_yaw_joint_ctrl" joint="left_thigh_joint" class="motor"
      ctrlrange="-8 8" forcerange="-8 8" />
    <motor name="left_hip_roll_joint_ctrl" joint="left_hip_roll_joint" class="motor"
      ctrlrange="-8 8" forcerange="-8 8" />
    <motor name="left_knee_joint_ctrl" joint="left_knee_joint" class="motor"
      ctrlrange="-8 8" forcerange="-8 8" />
    <motor name="left_ankle_pitch_ctrl" joint="left_ankle_cube_joint" class="motor"
      ctrlrange="-2.5 2.5" forcerange="-2.5 2.5" />
    <motor name="left_ankle_roll_ctrl" joint="left_ankle_axle_joint" class="motor"
      ctrlrange="-2.5 2.5" forcerange="-2.5 2.5" />
    <motor name="left_ankle_yaw_ctrl" joint="left_foot_joint" class="motor"
      ctrlrange="-2.5 2.5" forcerange="-2.5 2.5" />
    <motor name="left_toe_joint_ctrl" joint="left_toe_joint" class="motor"
      ctrlrange="-8 8" forcerange="-8 8" />
  </actuator>
